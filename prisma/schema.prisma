generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  manager
  viewer
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  email     String   @unique
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  role      Role
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("user_roles")
}

model Employee {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gid       BigInt   @unique
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  personalInfo      EmployeePersonalInfo[]
  climateResponses  ClimateSurveyResponse[]
  enpsAssignments   EnpsSurveyAssignment[]
  enpsResponses     EnpsSurveyResponse[]

  @@map("employees")
}

model EmployeePersonalInfo {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId        String   @map("employee_id") @db.Uuid
  nombres           String?
  primerApellido    String?  @map("primer_apellido")
  segundoApellido   String?  @map("segundo_apellido")
  validoDesde       DateTime @default(now()) @map("valido_desde")
  esActual          Boolean? @default(true) @map("es_actual")
  createdAt         DateTime @default(now()) @map("created_at")

  employee          Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_personal_info")
}

model UserModuleRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  module    String
  role      Role
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([userId, module])
  @@map("user_module_roles")
}

model ClimateSurvey {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  questions   Json     
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  
  responses   ClimateSurveyResponse[]

  @@map("climate_surveys")
}

model ClimateSurveyResponse {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  surveyId    String   @map("survey_id") @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  answers     Json
  submittedAt DateTime @default(now()) @map("submitted_at")

  survey      ClimateSurvey @relation(fields: [surveyId], references: [id])
  employee    Employee      @relation(fields: [employeeId], references: [id])

  @@map("climate_survey_responses")
}

// ── eNPS ─────────────────────────────────────────────────────────────────────

model EnpsSurvey {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  description      String?
  followUpQuestion String?   @map("follow_up_question")
  isActive         Boolean   @default(true) @map("is_active")
  scoreMin         Int       @default(0)  @map("score_min")
  scoreMax         Int       @default(10) @map("score_max")
  scoreLabels      Json?     @map("score_labels")
  createdAt        DateTime  @default(now()) @map("created_at")

  assignments      EnpsSurveyAssignment[]
  responses        EnpsSurveyResponse[]

  @@map("enps_surveys")
}

model EnpsSurveyAssignment {
  surveyId    String    @map("survey_id") @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  assignedAt  DateTime  @default(now()) @map("assigned_at")
  completedAt DateTime? @map("completed_at")

  survey   EnpsSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  employee Employee   @relation(fields: [employeeId], references: [id])

  @@id([surveyId, employeeId])
  @@map("enps_survey_assignments")
}

model EnpsSurveyResponse {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  surveyId       String   @map("survey_id") @db.Uuid
  employeeId     String   @map("employee_id") @db.Uuid
  score          Int
  followUpAnswer String?  @map("follow_up_answer")
  submittedAt    DateTime @default(now()) @map("submitted_at")

  survey   EnpsSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  employee Employee   @relation(fields: [employeeId], references: [id])

  @@unique([surveyId, employeeId])
  @@map("enps_survey_responses")
}
