# Base de datos PostgreSQL (Supabase connection pooling)
DATABASE_URL=postgres://postgres:<password>@db.<project-ref>.supabase.co:6543/postgres

# URL pública de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Clave anónima pública de Supabase (segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Clave de servicio de Supabase (NUNCA expongas al cliente, solo servidor)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
